 class CustomAppBarLayout(
     context: Context,
 ) : AppBarLayout(context) {
+    init {
+        // PATCH (core-mobile): disable Material3 lift-on-scroll. When content
+        // scrolls under the bar, AppBarLayout repaints itself with
+        // colorSurfaceContainer; on our transparent formsheet headers that
+        // surface shows as a darker band over the content and draws on top of
+        // the sheet grabber. We always supply our own headerBackground, so this
+        // auto-lift surface is never wanted — keep the bar transparent.
+        isLiftOnScroll = false
+        setBackgroundColor(Color.TRANSPARENT)
+    }
