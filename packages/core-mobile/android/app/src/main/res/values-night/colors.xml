<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="dialogTextColor">#FFFFFF</color>

    <!-- appSurfacePrimary backs colorSurface / android:colorBackground, which
         shows through the transparent formsheet header. The M3 baseline
         (#1C1B1F) is darker than the app surface ($surfacePrimary = neutral850
         #28282E) and bled through as a darker band on scroll, so match it.
         appSurfaceSecondary stays at the M3 baseline — it feeds
         colorSurfaceVariant/Container* used by native surfaces, and overriding
         it to neutral800 (#3E3E43) tinted those surfaces noticeably gray. -->
    <color name="appSurfacePrimary">#28282E</color>
    <color name="appSurfaceSecondary">#211F26</color>
</resources>