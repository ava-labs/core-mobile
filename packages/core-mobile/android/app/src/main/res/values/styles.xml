<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base theme containing all shared, mode-independent items.
         Both light and night AppTheme inherit from this so that
         resource-qualified style overrides (values-night/) don't
         accidentally drop window, system bar, or dialog settings. -->
    <style name="BaseAppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>

        <!--style for react-native-community/datetimepicker -->
        <item name="android:datePickerDialogTheme">@style/MyDatePickerDialogTheme</item>
        <item name="bottomNavigationStyle">@style/CustomBottomNavigationStyle</item>

        <!-- default tint color for dialog button text -->
        <item name="android:colorPrimary">@color/dialogTextColor</item>
        <item name="colorPrimary">@color/dialogTextColor</item>
    </style>

    <!-- Application theme for both light and dark mode.
         Overrides Material3 surface/container colors to prevent the default
         purple/lavender tint (from the M3 baseline seed color) from appearing
         as a pink header in light mode on Android.
         Light vs. dark surface values are driven by the resource-qualified color
         resources appSurfacePrimary and appSurfaceSecondary, defined in
         values/colors.xml (light) and values-night/colors.xml (dark). -->
    <style name="AppTheme" parent="BaseAppTheme">
        <item name="colorSurface">@color/appSurfacePrimary</item>
        <item name="android:colorBackground">@color/appSurfacePrimary</item>
        <item name="colorSurfaceVariant">@color/appSurfaceSecondary</item>
        <item name="colorSurfaceContainerLowest">@color/appSurfacePrimary</item>
        <item name="colorSurfaceContainerLow">@color/appSurfacePrimary</item>
        <item name="colorSurfaceContainer">@color/appSurfaceSecondary</item>
        <item name="colorSurfaceContainerHigh">@color/appSurfaceSecondary</item>
        <item name="colorSurfaceContainerHighest">@color/appSurfaceSecondary</item>
    </style>

    <style name="CustomBottomNavigationStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="elevation">1dp</item>
        <item name="itemActiveIndicatorStyle">@null</item> <!--disable active indicator -->
        <item name="itemBackground">@null</item> <!--disable ripple effect -->
    </style>

    <style name="MyDatePickerDialogTheme" parent="Theme.Material3.Light.Dialog">
        <!-- Calendar background color -->
        <item name="android:windowBackground">@color/neutral850</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/neutral50</item>
        <item name="android:textColorPrimaryInverse">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/neutral400</item>
        <item name="android:textColorSecondaryInverse">@color/neutral400</item>

        <!-- Selected item color -->
        <item name="colorControlActivated">@color/neutral50</item>

        <!-- Dialog button text color -->
        <item name="android:textColor">@color/neutral50</item>
        <item name="colorAccent">@color/neutral50</item> <!-- May be needed for older Androids -->
        <item name="colorPrimary">@color/neutral50</item>

        <!-- Date picker style -->
        <item name="android:datePickerStyle">@style/MyDatePickerStyle</item>
    </style>

    <style name="MyDatePickerStyle" parent="@android:style/Widget.Material.Light.DatePicker">
        <!-- header backgrond color-->
        <item name="android:headerBackground">@color/white</item>
    </style>

    <!-- BootTheme should inherit from Theme.BootSplash or Theme.BootSplash.EdgeToEdge -->
    <style name="BootTheme" parent="Theme.BootSplash.EdgeToEdge">
        <item name="bootSplashBackground">@color/bootsplash_background</item>
        <item name="bootSplashLogo">@drawable/bootsplash_logo</item>
        <item name="postBootSplashTheme">@style/AppTheme</item>
    </style>

</resources>
